DOTNET_ENVIRONMENT=Production
ActionNetwork__ApiToken=replace-with-action-network-api-token
Keycloak__BaseUrl=http://127.0.0.1:8080/
Keycloak__Realm=greenparty-local
Keycloak__AuthenticationRealm=master
Keycloak__AdminClientId=admin-cli
Keycloak__AdminUsername=admin
Keycloak__AdminPassword=replace-with-keycloak-admin-password
Keycloak__VerifySsl=false
Sync__IntervalMinutes=15
Sync__StateStorePath=/var/lib/greenparty-identity-sync/identity-sync.db
Sync__DryRun=false
Sync__DisableUsersMissingFromSource=false
Sync__RunImmediatelyOnStart=false
